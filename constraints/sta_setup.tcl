# ============================================================================
# sta_setup.tcl — OpenSTA Multi-Corner Setup for ADAS v2 SoC
# ============================================================================
# Project:   adas_v2 — ADAS RISC-V High-Performance Safety-Critical SoC
# Author:    Marcus Osei, STA/Timing Signoff Engineer
# Date:      2026-04-29
# Usage:     /usr/bin/sta sta_setup.tcl
#            OR: sta -no_init -exit sta_setup.tcl
#
# Required inputs:
#   - Post-synthesis netlist: synth/adas_v2_synth.v
#   - SDC constraints:        constraints/adas_v2.sdc
#   - Liberty files:          (see LIBERTY PATHS below)
#
# ============================================================================
# PDK NOTE — sky130_fd_sc_hs LIBERTY CORNER AVAILABILITY
# ============================================================================
# The sky130_fd_sc_hs (High-Speed) variant of SkyWater 130nm provides ONLY
# Typical-Typical (TT) corner characterization in the released PDK:
#
#   ✅ TT @ 25°C, 1.80V: sky130_fd_sc_hs__tt_025C_1v80.lib
#   ✅ TT @ 100°C, 1.80V: sky130_fd_sc_hs__tt_100C_1v80.lib
#
# No SS (Slow-Slow) or FF (Fast-Fast) corners are available for the HS variant.
# This is a PDK limitation — the sky130_fd_sc_hd (High-Density) variant has
# SS/FF corners, but HS does not.
#
# For signoff-quality multi-corner STA, consider:
#   Option A: Run Yosys synthesis targeting sky130_hd cells with full SS/FF libs
#   Option B: Use derating factors on TT corners (not a true STA signoff)
#   Option C: Accept TT-only signoff for prototype / tapeout (e.g., Efabless MPW)
#
# This script is configured for TT-only STA with both available corners.
# ============================================================================

# ============================================================================
# 1. SCRIPT CONFIGURATION
# ============================================================================
# Set your project root — adjust if running from a different directory
set proj_root [file dirname [file dirname [info script]]]

# --- Liberty File Paths ---
# Sky130 HS Liberty files from ORFS platform directory
set liberty_tt_25  "/home/smdadmin/OpenROAD-flow-scripts/flow/platforms/sky130hs/lib/sky130_fd_sc_hs__tt_025C_1v80.lib"
set liberty_tt_100 "/home/smdadmin/OpenROAD-flow-scripts/flow/platforms/sky130hs/lib/sky130_fd_sc_hs__tt_100C_1v80.lib"

# --- Netlist ---
# Post-synthesis netlist (generated by Yosys / ORFS synthesis flow)
# Using -noexpr -nodec variant for OpenSTA parser compatibility
set netlist_path "[file join $proj_root synth adas_v2_synth_sta.v]"

# --- SDC ---
set sdc_path "[file join $proj_root constraints adas_v2.sdc]"


# ============================================================================
# 2. CORNER CONFIGURATION
# ============================================================================
# Define corners. In a full STA flow, each corner is sourced separately
# in its own STA run. For OpenSTA, we process corners sequentially.

# Corner Definitions (informational — actual corner loaded per-section):
# ┌────────┬──────────────────────────────────────────┬──────────────────┐
# │ Corner │ Library File                             │ Purpose          │
# ├────────┼──────────────────────────────────────────┼──────────────────┤
# │ TT_25  │ sky130_fd_sc_hs__tt_025C_1v80.lib       │ Functional STA   │
# │ TT_100 │ sky130_fd_sc_hs__tt_100C_1v80.lib       │ Temp corner STA  │
# └────────┴──────────────────────────────────────────┴──────────────────┘


# ============================================================================
# 3. CORNER: TT @ 25°C, 1.80V (Nominal)
# ============================================================================
puts "\n============================================================"
puts "  CORNER: TT @ 25°C, 1.80V (Nominal Operating Condition)"
puts "============================================================\n"

# --- Check liberty file exists ---
if {![file exists $liberty_tt_25]} {
    puts "ERROR: Liberty file not found: $liberty_tt_25"
    puts "Skipping TT_25 corner."
} else {
    # Load liberty
    read_liberty $liberty_tt_25
    puts "Loaded: $liberty_tt_25"

    # Load netlist (if available)
    if {[file exists $netlist_path]} {
        read_verilog $netlist_path
        puts "Loaded netlist: $netlist_path"

        # Link design
        link_design adas_soc_top
    } else {
        puts "WARNING: Netlist not found at $netlist_path"
        puts "  Skipping design link. STA requires post-synthesis netlist."
        puts "  Run synthesis first (Yosys or ORFS flow)."
    }

    # Read SDC
    if {[file exists $sdc_path]} {
        read_sdc $sdc_path
        puts "Loaded SDC: $sdc_path"
    } else {
        puts "ERROR: SDC file not found: $sdc_path"
    }

    # --- Timing Reports ---
    # Only run if netlist was loaded
    if {[file exists $netlist_path]} {
        puts "\n--- Setup (Max Path) Report ---"
        report_checks -path_delay max -fields {cap slew input_pin} -format full_clock_expanded

        puts "\n--- Hold (Min Path) Report ---"
        report_checks -path_delay min -fields {cap slew input_pin} -format full_clock_expanded

        puts "\n--- Worst Negative Slack (WNS) Summary ---"
        report_wns

        puts "\n--- Total Negative Slack (TNS) Summary ---"
        report_tns

        puts "\n--- Clock Skew Report ---"
        report_clock_skew

        puts "\n--- Design Area (Cell Count) ---"
        report_design_area
    }
}


# ============================================================================
# 4. CORNER: TT @ 100°C, 1.80V (High Temperature)
# ============================================================================
puts "\n============================================================"
puts "  CORNER: TT @ 100°C, 1.80V (High-Temperature Condition)"
puts "============================================================\n"

if {![file exists $liberty_tt_100]} {
    puts "ERROR: Liberty file not found: $liberty_tt_100"
    puts "Skipping TT_100 corner."
} else {
    # OpenSTA note: re-reading liberty requires clearing previous.
    # Use reset_liberty_libraries if available, or start a fresh STA session.
    # For single-script convenience, we proceed if the tool supports re-reading.

    read_liberty $liberty_tt_100
    puts "Loaded: $liberty_tt_100"

    if {[file exists $netlist_path]} {
        read_verilog $netlist_path
        link_design adas_soc_top
        read_sdc $sdc_path

        puts "\n--- Setup (Max Path) Report @ TT_100 ---"
        report_checks -path_delay max -fields {cap slew input_pin} -format full_clock_expanded

        puts "\n--- Hold (Min Path) Report @ TT_100 ---"
        report_checks -path_delay min -fields {cap slew input_pin} -format full_clock_expanded
    }
}


# ============================================================================
# 5. FINAL SIGN-OFF CHECKLIST
# ============================================================================
puts "\n============================================================"
puts "  STA SIGN-OFF CHECKLIST"
puts "============================================================"
puts " [ ] TT_25 corner — setup slack all positive"
puts " [ ] TT_25 corner — hold slack all positive"
puts " [ ] TT_100 corner — setup slack all positive"
puts " [ ] TT_100 corner — hold slack all positive"
puts " [ ] No unconstrained endpoints"
puts " [ ] Clock groups match cdc_plan.md"
puts " [ ] All CDC crossings have set_false_path"
puts " [ ] I/O delays conservative (30% of period)"
puts " [ ] Asynchronous reset recovery/removal reviewed"
puts " [ ] Test mode paths excluded from functional STA"
puts ""
puts "  ⚠ LIMITATIONS (sky130hs):"
puts "   - No SS (Slow-Slow) corner available"
puts "   - No FF (Fast-Fast) corner available"
puts "   - Multi-corner STA limited to TT only"
puts "   - For production signoff, re-target sky130_hd with full corners"
puts "============================================================\n"

puts "STA setup complete. Check reports above for violations."
