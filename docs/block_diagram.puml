@startuml adas_v2_top
!define BLOCK_HIGHLIGHT #E1F5FE
!define MEM_BLOCK #FFF9C4
!define SAFETY_BLOCK #FFCDD2
!define PERIPH_BLOCK #C8E6C9
!define BUS_BLOCK #FFE0B2

skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam packageBorderColor #333333
skinparam packageFontSize 11
skinparam packageFontStyle bold

' ============================================================================
' CLOCK DOMAINS
' ============================================================================
rectangle "CLOCK GENERATION" as CLKGEN BLOCK_HIGHLIGHT {
  [sys_osc] as SYSOSC
  [wdt_osc] as WDTOSC
  [sys_pll] as SYSPLL
}

' ============================================================================
' RV32IM CORE + MEMORY SUBSYSTEM
' ============================================================================
package "RV32IM CORE (sys_clk)" as COREPKG MEM_BLOCK {
  [RV32IM\n3-stage pipeline\nFetch→Decode→Execute] as CORE
  [ITCM\n8KB SRAM] as ITCM
  [DTCM\n8KB SRAM] as DTCM
}

' ============================================================================
' AXI4-LITE INTERCONNECT
' ============================================================================
package "AXI4-Lite Interconnect" as INTERCONNECT BUS_BLOCK {
  [1-to-N\nAddress\nDecoder] as AXI_XBAR
}

' ============================================================================
' AI ACCELERATOR
' ============================================================================
package "AI Accelerator (sys_clk)" as AIPKG BLOCK_HIGHLIGHT {
  [4×4 INT8\nSystolic Array\n(Weight-Stationary)] as AI_ARRAY
  [AXI4-L\nSlave\nIF] as AI_IF
  [Weight\nBuffer\nSRAM] as WBUF
  [Input\nBuffer\nSRAM] as IBUF
  [Output\nBuffer\nSRAM] as OBUF
}

' ============================================================================
' PERIPHERALS
' ============================================================================
package "PERIPHERALS (sys_clk)" as PERIPHPKG PERIPH_BLOCK {
  [SPI Controller\n(SPI Master)\nLIDAR Interface] as SPI
  [Servo PWM\n(Braking\nActuator)] as SERVO
  [Speed Sensor\n(Pulse Counter\n+ Timestamps)] as SPEED
  [Buzzer PWM\n(Audible Alert)] as BUZZER
  [UART 16550\n(Debug\nConsole)] as UART
  [GPIO\n32-bit\nAlert/Shutdown] as GPIO
}

' ============================================================================
' SAFETY SUBSYSTEM
' ============================================================================
package "SAFETY SUBSYSTEM" as SAFETYPKG SAFETY_BLOCK {
  package "sys_clk Domain" {
    [Lockstep\nComparator] as LOCKSTEP
    [Fault\nAggregator] as FAULTAGG
    [Safety\nControl\nRegister] as SAFECTRL
  }
  package "wdt_clk Domain" {
    [Window\nWatchdog\nTimer] as WDT
    [Redundant\nShutdown\nController] as RSC
  }
}

' ============================================================================
' CONNECTIONS
' ============================================================================

' Clock distribution
SYSOSC -down-> SYSPLL : ref_clk
SYSPLL -down-> CORE : sys_clk
SYSPLL -down-> INTERCONNECT : sys_clk
SYSPLL -down-> AIPKG : sys_clk
SYSPLL -down-> PERIPHPKG : sys_clk
SYSPLL -down-> LOCKSTEP : sys_clk
SYSPLL -down-> FAULTAGG : sys_clk
WDTOSC -down-> WDT : wdt_clk
WDTOSC -down-> RSC : wdt_clk

' Core memory
CORE -up-> ITCM : instruction fetch
CORE -up-> DTCM : load/store

' Core to Interconnect
CORE -down-> AXI_XBAR : AXI4-Lite Master

' Interconnect to Peripherals
AXI_XBAR -down-> AI_IF : AI Accel (0x1000)
AXI_XBAR -down-> SPI : SPI (0x2000)
AXI_XBAR -down-> SERVO : Servo PWM (0x3000)
AXI_XBAR -down-> SPEED : Speed Sensor (0x4000)
AXI_XBAR -down-> BUZZER : Buzzer PWM (0x5000)
AXI_XBAR -down-> UART : UART (0x6000)
AXI_XBAR -down-> GPIO : GPIO (0x7000)
AXI_XBAR -down-> SAFECTRL : Safety Ctrl (0xF000)
AXI_XBAR -down-> WDT : Watchdog (0xF100)

' AI Accelerator internal
AI_IF -down-> AI_ARRAY : control
AI_IF -down-> WBUF : weight load
AI_IF -down-> IBUF : input load
AI_ARRAY -up-> OBUF : output

' Safety monitor connections
CORE -down-> LOCKSTEP : core outputs + PC
LOCKSTEP -down-> FAULTAGG : mismatch_detected
FAULTAGG -down-> RSC : aggregated_fault
SPI -up-> FAULTAGG : spi_error
SERVO -up-> FAULTAGG : servo_fault
SPEED -up-> FAULTAGG : sensor_stuck
WDT -up-> FAULTAGG : wdt_timeout

' Redundant shutdown
RSC -down-> GPIO : force_shutdown
GPIO -down-> (Alert_Out) : alert_outputs
GPIO -down-> (Shutdown) : redundant_shutdown

' ASIC external interfaces
SPI -down-> (SPI_Pads) : SCK,MOSI,MISO,CS
SERVO -down-> (Servo_PWM_Out) : pwm_out
SPEED -up-> (Speed_Pulse_In) : pulse_in
BUZZER -down-> (Buzzer_PWM_Out) : buzzer_pwm
UART -down-> (UART_Pads) : TX,RX

@enduml
